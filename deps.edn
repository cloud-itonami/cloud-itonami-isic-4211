{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace. This repo is standalone
 ;; (forkable outside the workspace); the :local/root paths only resolve
 ;; inside the monorepo checkout — a standalone fork should override them
 ;; with git coordinates. `construction.notify`'s real Resend/Twilio
 ;; transports use only `java.net.http` + a hand-rolled minimal JSON/form
 ;; encoder (see ns docstring) -- no extra HTTP/JSON library dependency.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/robotics
        {:local/root "../../kotoba-lang/robotics"}
        ;; REAL time-stepped physics dependency (ADR-2607152000, extending
        ;; ADR-2607151600's automotive pilot to this vertical):
        ;; construction.simphysics actually calls physics-2d/world-step to
        ;; run a real press-platen-vs-test-cylinder rigid-body collision
        ;; simulation for the concrete-cure test-cylinder compressive-
        ;; strength press mission step, instead of comparing only static
        ;; self-reported fields. Unlike automotive (which depends on a
        ;; sibling design-repo, kami-engine-vehicle-designer, that itself
        ;; depends on physics-2d transitively), construction has no such
        ;; sibling and depends on physics-2d directly.
        io.github.kotoba-lang/physics-2d
        {:git/url "https://github.com/kotoba-lang/physics-2d.git"
         :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "construction.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
